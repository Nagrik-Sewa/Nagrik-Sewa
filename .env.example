# ==================================
# CORE APPLICATION CONFIGURATION
# ==================================

# Environment: development | production | test
NODE_ENV=development
PORT=5000

# ==================================
# DATABASE CONFIGURATION (REQUIRED)
# ==================================
# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Skip database connection (for frontend-only development)
# SKIP_DB_CONNECTION=true

# ==================================
# AUTHENTICATION & SECURITY (REQUIRED)
# ==================================

# JWT Configuration - MUST be set for authentication to work
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_at_least_64_characters
JWT_EXPIRES_IN=7d

# Refresh Token (optional, defaults to JWT_SECRET if not set)
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d

# Password Encryption
BCRYPT_ROUNDS=12

# ==================================
# FRONTEND URLS
# ==================================
# Production examples (Render + Vercel)
FRONTEND_URL=https://your-frontend-app.vercel.app
VITE_API_URL=https://your-backend-app.onrender.com
VITE_SOCKET_URL=https://your-backend-app.onrender.com

# Optional local development overrides
# CLIENT_URL=http://localhost:5173
# FRONTEND_URL=http://localhost:5173
# VITE_API_URL=http://localhost:5000
# VITE_SOCKET_URL=http://localhost:5000

# ==================================
# AI & CHATBOT CONFIGURATION
# ==================================

# Google Gemini AI (Required for AI features)
# Get from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ==================================
# GOOGLE OAUTH (Optional)
# ==================================
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here

# ==================================
# EMAIL SERVICE (Optional)
# ==================================
# EmailJS Configuration
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# ==================================
# SMS SERVICE (Optional)
# ==================================
# Twilio or similar SMS provider
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==================================
# RATE LIMITING
# ==================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# ==================================
# METRICS (Production)
# ==================================
METRICS_AUTH_TOKEN=your_metrics_auth_token