# ==================================
# CORE APPLICATION CONFIGURATION
# ==================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
REQUEST_BODY_LIMIT=10mb
LOG_REQUESTS=true
HTTP_LOG_FORMAT=combined

# ==================================
# DATABASE CONFIGURATION (REQUIRED)
# ==================================
# IMPORTANT: If your password has special chars like @, use URL-encoded value (%40)
MONGODB_URI=mongodb+srv://nagriksewaconnect_db_user:<db_password>@nagriksewa.4x4zgbm.mongodb.net/?appName=NagrikSewa

# Optional DB tuning
DB_CONNECT_RETRIES=3
DB_RETRY_DELAY_MS=2000
DB_MAX_POOL_SIZE=10
DB_MIN_POOL_SIZE=1
DB_SERVER_SELECTION_TIMEOUT_MS=5000
DB_CONNECT_TIMEOUT_MS=10000
DB_SOCKET_TIMEOUT_MS=60000
DB_HEARTBEAT_MS=10000

# Frontend-only mode
# SKIP_DB_CONNECTION=true

# ==================================
# AUTHENTICATION & SECURITY (REQUIRED)
# ==================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_secure_secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace_with_different_secure_secret
REFRESH_TOKEN_EXPIRES_IN=30d

# Optional system-admin login (disabled by default)
ENABLE_SYSTEM_ADMIN_LOGIN=false
SYSTEM_ADMIN_EMAIL=
SYSTEM_ADMIN_PASSWORD=
SYSTEM_ADMIN_FIRST_NAME=System
SYSTEM_ADMIN_LAST_NAME=Administrator

# Optional one-time admin bootstrap endpoint (disabled by default)
ENABLE_ADMIN_BOOTSTRAP=false
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_BOOTSTRAP_FIRST_NAME=Admin
ADMIN_BOOTSTRAP_LAST_NAME=User

# ==================================
# FRONTEND URLS
# ==================================
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# ==================================
# AI & CHATBOT CONFIGURATION
# ==================================
# Server-side key (recommended)
GEMINI_API_KEY=
# Frontend fallback key (only if absolutely required)
VITE_GEMINI_API_KEY=

# ==================================
# GOOGLE OAUTH
# ==================================
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==================================
# EMAIL SERVICE
# ==================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="Nagrik Sewa" <noreply@nagriksewa.com>
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# ==================================
# SMS SERVICE
# ==================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================================
# PAYMENTS & VERIFICATION
# ==================================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=

# ==================================
# SUPPORT & OBSERVABILITY
# ==================================
WORKER_SUPPORT_EMAIL=support@nagriksewa.com
WORKER_SUPPORT_PHONE=+917983454047
SUPPORT_EMAIL=support@nagriksewa.com
METRICS_AUTH_TOKEN=replace_with_metrics_bearer_token
PING_MESSAGE=ping

# ==================================
# LIMITS & RATE LIMITING
# ==================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW_MS=60000
OTP_RATE_LIMIT_MAX=1
MAX_FILE_SIZE=5242880
BCRYPT_ROUNDS=12
